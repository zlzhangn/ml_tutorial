   "cell_type": "code",
   "source": [
    "X = [[2, 1], [3, 1], [1, 4], [2, 6]]\n",
    "y = [0.5, 1.5, 4, 3.2]\n",
    "\n",
    "# 创建模型\n",
    "knn = KNeighborsRegressor(n_neighbors=2)\n",
    "\n",
    "# 训练\n",
    "knn.fit(X, y)\n",
    "\n",
    "print(knn.predict([[4, 9]]))"
   ],
